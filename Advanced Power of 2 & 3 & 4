#include <iostream>
#include <string>
using namespace std;
int readNumber()
{
	int Num;
	cout << "please enter number to power it :";
	cin >> Num;
	return Num;
}
void PrintPowerOf_2_3_4(int Num)
{
	int a, b, c;
	a = Num * Num;
	b = Num * Num * Num;
	c = Num * Num * Num * Num;
	cout << Num << "^2=" << a << endl;
	cout << Num << "^3=" << b << endl;
	cout << Num << "^4=" << c << endl;
}
int main()
{
	PrintPowerOf_1_2_3(readNumber());
	return 0;
}
